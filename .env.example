# Copy this file to .env and fill in your values.
# .env is gitignored — this file is safe to commit.

DB_URL=jdbc:postgresql://localhost:5432/amigoscode
DB_USERNAME=postgres
DB_PASSWORD=password

# For Supabase (staging/prod): use port 6543 (PgBouncer), not 5432
# DB_URL=jdbc:postgresql://db.<PROJECT_REF>.supabase.co:6543/postgres?pgbouncer=true&sslmode=require

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

CORS_ORIGINS=http://localhost:3000

GOVT_API_URL=https://api.labour.gov.in/minimum-wage
GOVT_API_TIMEOUT_MS=5000
